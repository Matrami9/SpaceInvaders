{
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": [
    "google",
    "plugin:@typescript-eslint/recommended"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2021": true
  },
  "rules": {
  "require-jsdoc": "off",
  "valid-jsdoc": "off",
  "max-len": ["error", {"code": 120}],
  "no-unused-vars": "off",
  "@typescript-eslint/no-unused-vars": ["warn"],
  "@typescript-eslint/no-unused-expressions": "off" 
}
}